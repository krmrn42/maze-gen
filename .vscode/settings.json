{
  "cSpell.words": [
    "Aldous",
    "Appender",
    "Backtracker",
    "Broder",
    "BSON",
    "CHTA",
    "cobertura",
    "coverlet",
    "docfx",
    "netcoredbg",
    "nettrace",
    "reportgenerator",
    "speedscope",
    "ELKK",
    "Hermione",
    "HYNA",
    "mazegen",
    "Memberwise",
    "msbuild",
    "nunit",
    "OTTR",
    "PNDA",
    "RABB",
    "RINO",
    "stddev",
    "unpositioned",
    "Wilsons",
    "Yennefer",
    "ZEBR"
  ],
  // Run background code analysis for: (Previously `omnisharp.enableRoslynAnalyzers`)
  //  - openFiles: Open documents
  //  - fullSolution: Entire solution
  //  - none: None
  "dotnet.backgroundAnalysis.analyzerDiagnosticsScope": "fullSolution",
  // Show compiler errors and warnings for:
  //  - openFiles: Open documents
  //  - fullSolution: Entire solution
  //  - none: None
  "dotnet.backgroundAnalysis.compilerDiagnosticsScope": "fullSolution",
  "dotnet.preferCSharpExtension": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.renderFinalNewline": "on",
  "editor.rulers": [
    80,
  ],
  "todo-tree.tree.scanMode": "workspace only",
  "todo-tree.tree.showBadges": false,
  "watch-run.targetList": [
    {
        "target": "**/*.cs",
        "task": "build"
    }
  ]
}